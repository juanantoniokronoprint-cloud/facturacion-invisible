ENVIRONMENT=production
APP_DEBUG=false

# Obligatorio en producción. Usar un secreto largo y aleatorio.
API_KEY=change-me-long-random-secret

# Separar por comas. No usar "*" en producción.
ALLOWED_ORIGINS=https://facturacion.example.com
PUBLIC_BASE_URL=https://facturacion.example.com

# Webhooks: configurar el mismo secreto en Telegram/bridge WhatsApp.
TELEGRAM_WEBHOOK_SECRET=change-me-telegram-secret
WHATSAPP_WEBHOOK_SECRET=change-me-whatsapp-secret

# En producción segura queda en outbox. Cambiar a live solo tras prueba controlada.
EMAIL_SEND_MODE=outbox
GOG_ACCOUNT=

DATABASE_URL=sqlite:///./facturas.db

OPENAI_API_KEY=
TELEGRAM_BOT_TOKEN=
VERIFACTI_API_KEY=
VERIFACTI_SEND_MODE=demo

EMISOR_NIF=
EMISOR_NOMBRE=
EMISOR_DOMICILIO=
EMISOR_CP=
EMISOR_POBLACION=
EMISOR_PROVINCIA=
EMISOR_CLAVE_REGIMEN=01

IVA_DEFAULT=21
IRPF_DEFAULT=15

CONTABILIDAD_EMAIL=
ASESOR_EMAIL=
TELEFONOS_AUTORIZADOS=
